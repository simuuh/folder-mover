# Folder Mover - Configuration
# Copy this file to config.yaml and adjust to your setup.

# ── Paths ──────────────────────────────────────────────────────────────────────
download_dir: /home/user/Downloads
movies_dir: /mnt/Filme
series_dir: /mnt/Serien

# ── Web Server ─────────────────────────────────────────────────────────────────
port: 8080

# ── Authentication (Basic Auth) ────────────────────────────────────────────────
auth:
  username: admin
  password: changeme          # change this!

# ── Video file extensions to recognize ────────────────────────────────────────
video_extensions:
  - .mkv
  - .mp4
  - .avi
  - .m4v
  - .ts
  - .m2ts

# ── Episode detection patterns ────────────────────────────────────────────────
# These are Python regex patterns. They are tried in order.
# You shouldn't need to change these normally.
episode_patterns:
  - '(?i)S(\d{1,2})E(\d{1,2})'         # S01E01
  - '(?i)(\d{1,2})x(\d{2})'            # 1x01
  - '(?i)(Folge|Episode|Ep)[._\- ]?(\d{1,3})'  # Folge 01
